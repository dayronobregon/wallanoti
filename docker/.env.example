# =========================================
# Docker Compose Environment Variables
# =========================================
# Copy this file to .env and configure your values:
#   cp .env.example .env

COMPOSE_PROJECT_NAME=wallanoti
HOSTNAME=localhost

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Message Broker
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin

# API Configuration (for full stack deployment)
ASPNETCORE_ENVIRONMENT=Development
JWT_SECRET=CHANGE_ME_USE_ENV_OR_USER_SECRETS_MIN_32_CHARS
JWT_ISSUER=YOUR_APP_NAME
JWT_AUDIENCE=YOUR_AUDIENCE

# Telegram Bot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_OWNER_CHAT_ID=YOUR_TELEGRAM_OWNER_CHAT_ID

# Frontend (Vite build-time)
# Docker Compose functional example:
# - Leave VITE_SIGNALR_URL empty to use nginx proxy (/hub -> api)
# - Or point directly to the API if you prefer
VITE_API_BASE_URL=/api
VITE_SIGNALR_URL=http://localhost:8080
VITE_TELEGRAM_BOT=@your_bot_username
